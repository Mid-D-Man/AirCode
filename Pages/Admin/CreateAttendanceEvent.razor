@page "/Admin/CreateSession"
@using AirCode.Layout.AdminLayout.Superior
@using Microsoft.AspNetCore.Authorization
@layout SuperiorAdminLayout
@attribute [Authorize(Roles = "LecturerAdmin")]
@using AirCode.Components.SharedPrefabs
@using AirCode.Utilities.DataStructures
@using AirCode.Components.SharedPrefabs.QrCode
@using AirCode.Components.SharedPrefabs.Buttons
@inject IJSRuntime JS
@inject QRCodeDecoder QRCodeDecoder

<div class="create-session-page">
    <h1>Create Session</h1>
    
    <div class="content-container @(isSessionStarted ? "session-active" : "")">
        <div class="form-container">
            <EditForm Model="sessionModel" OnValidSubmit="StartSession">
                <DataAnnotationsValidator />
                <ValidationSummary />
                
                <div class="form-group">
                    <label for="courseName">Course Name</label>
                    <InputText id="courseName" @bind-Value="sessionModel.CourseName" class="form-control" disabled="@isSessionStarted" />
                </div>
                
                <div class="form-group">
                    <label for="courseId">Course ID</label>
                    <InputText id="courseId" @bind-Value="sessionModel.CourseId" class="form-control" disabled="@isSessionStarted" />
                </div>
                
                <div class="form-group">
                    <label for="duration">Session Duration</label>
                    <InputSelect id="duration" @bind-Value="sessionModel.Duration" class="form-control" disabled="@isSessionStarted">
                        <option value="10">10 minutes</option>
                        <option value="15">15 minutes</option>
                        <option value="30">30 minutes</option>
                        <option value="60">1 hour</option>
                        <option value="120">2 hours</option>
                        <option value="180">3 hours</option>
                        <option value="240">4 hours</option>
                        <option value="300">5 hours</option>
                        <option value="360">6 hours</option>
                    </InputSelect>
                </div>
                
                <div class="form-group">
                    <label for="qrTheme">QR Code Theme</label>
                    <InputSelect id="qrTheme" @bind-Value="selectedTheme" class="form-control" disabled="@isSessionStarted">
                        <option value="Standard">Standard</option>
                        <option value="Gradient">Gradient</option>
                        <option value="Branded">With Logo</option>
                        <option value="GradientWithLogo">Gradient with Logo</option>
                    </InputSelect>
                </div>
                
                <div class="button-container">
                    <PrimaryButton Text="Start Session" OnClick="StartSession" />
                </div>
            </EditForm>
        </div>
        
        @if (isSessionStarted)
        {
            <div class="active-session-container">
                <div class="countdown-timer">
                    Session ends in: @FormatTimeRemaining()
                </div>
                
                <div class="qr-code-wrapper">
                    <QRCodeCompo 
                        Content="@qrCodePayload" 
                        Duration="@sessionModel.Duration" 
                        Theme="@ConvertStringToTheme(selectedTheme)" 
                        Options="@GenerateQRCodeOptions()"
                        OnGenerated="HandleQRCodeGenerated" />
                </div>
                
                <div class="session-actions">
                    <button class="floating-qr-icon" @onclick="OpenFloatingQR" title="Open Floating QR Code">
                        <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M3 11h8V3H3v8zm2-6h4v4H5V5zM3 21h8v-8H3v8zm2-6h4v4H5v-4zM13 3v8h8V3h-8zm6 6h-4V5h4v4zM19 13h2v2h-2zM13 13h2v2h-2zM15 15h2v2h-2zM13 17h2v2h-2zM15 19h2v2h-2zM17 17h2v2h-2zM19 19h2v2h-2zM17 15h2v2h-2z"/>
                        </svg>
                    </button>
                    <PrimaryButton Text="End Session" OnClick="EndSession" />
                </div>
            </div>
        }
    </div>
    
    <!-- Active Sessions List -->
    @if (activeSessions.Any())
    {
        <div class="active-sessions-list">
            <h3>Active Sessions</h3>
            @foreach (var session in activeSessions)
            {
                <div class="session-card">
                    <div class="session-info">
                        <strong>@session.CourseName (@session.CourseId)</strong>
                        <span class="session-time">Ends: @session.EndTime.ToString("HH:mm")</span>
                    </div>
                    <button class="qr-icon-button" @onclick="() => OpenFloatingQRForSession(session)" title="Show QR Code">
                        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M3 11h8V3H3v8zm2-6h4v4H5V5zM3 21h8v-8H3v8zm2-6h4v4H5v-4zM13 3v8h8V3h-8zm6 6h-4V5h4v4z"/>
                        </svg>
                    </button>
                </div>
            }
        </div>
    }
</div>

<!-- Floating QR Code Window -->
@if (showFloatingQR)
{
    <div class="floating-qr-overlay" @onclick="CloseFloatingQR">
        <div class="floating-qr-window" @onclick:stopPropagation="true" style="@floatingWindowStyle">
            <div class="floating-qr-header">
                <div class="drag-handle" @onmousedown="StartDrag" @ontouchstart="StartDrag">
                    <span>QR Code - @floatingSessionData?.CourseName</span>
                </div>
                <button class="close-button" @onclick="CloseFloatingQR">×</button>
            </div>
            <div class="floating-qr-content">
                <div class="floating-countdown">
                    Expires in: @FormatFloatingTimeRemaining()
                </div>
                @if (floatingSessionData != null)
                {
                    <QRCodeCompo 
                        Content="@floatingSessionData.QrCodePayload" 
                        Duration="@floatingSessionData.Duration" 
                        Theme="@ConvertStringToTheme(floatingSessionData.Theme)" 
                        Options="@GenerateFloatingQRCodeOptions()" />
                }
            </div>
        </div>
    </div>
}

@code {
    private SessionData sessionModel = new();
    private bool isSessionStarted = false;
    private string qrCodePayload = string.Empty;
    private string selectedTheme = "Standard";
    private DateTime sessionEndTime;
    private System.Threading.Timer countdownTimer;
    private QRCodeData generatedQRCode;
    private List<ActiveSessionData> activeSessions = new();
    
    // Floating QR code properties
    private bool showFloatingQR = false;
    private ActiveSessionData floatingSessionData;
    private string floatingWindowStyle = "top: 50px; left: 50px;";
    private bool isDragging = false;
    private double dragStartX, dragStartY, windowStartX, windowStartY;
    private System.Threading.Timer floatingCountdownTimer;

    protected override void OnInitialized()
    {
        sessionModel.Duration = 30;
    }
    
    private async void StartSession()
    {
        sessionModel.StartTime = DateTime.UtcNow;
        sessionModel.Date = DateTime.UtcNow.Date;
        isSessionStarted = true;
        qrCodePayload = await GenerateQrCodePayload();
        
        sessionEndTime = DateTime.UtcNow.AddMinutes(sessionModel.Duration);
        
        // Add to active sessions list
        var activeSession = new ActiveSessionData
        {
            SessionId = Guid.NewGuid().ToString("N"),
            CourseName = sessionModel.CourseName,
            CourseId = sessionModel.CourseId,
            StartTime = sessionModel.StartTime,
            EndTime = sessionEndTime,
            Duration = sessionModel.Duration,
            QrCodePayload = qrCodePayload,
            Theme = selectedTheme
        };
        activeSessions.Add(activeSession);
        
        countdownTimer = new System.Threading.Timer(
            _ => InvokeAsync(() => {
                StateHasChanged();
                CleanupExpiredSessions();
            }),
            null,
            TimeSpan.Zero,
            TimeSpan.FromSeconds(1)
        );
    }
    
    private void EndSession()
    {
        isSessionStarted = false;
        countdownTimer?.Dispose();
        countdownTimer = null;
        
        // Remove from active sessions
        activeSessions.RemoveAll(s => s.QrCodePayload == qrCodePayload);
    }
    
    private async Task<string> GenerateQrCodePayload()
    {
        var sessionId = Guid.NewGuid().ToString("N");
        
        return await QRCodeDecoder.EncodeSessionDataAsync(
            sessionId,
            sessionModel.CourseId,
            sessionModel.StartTime,
            sessionModel.Duration);
    }
    
    private void OpenFloatingQR()
    {
        if (isSessionStarted)
        {
            var currentSession = activeSessions.FirstOrDefault(s => s.QrCodePayload == qrCodePayload);
            if (currentSession != null)
            {
                OpenFloatingQRForSession(currentSession);
            }
        }
    }
    
    private void OpenFloatingQRForSession(ActiveSessionData session)
    {
        floatingSessionData = session;
        showFloatingQR = true;
        
        // Start floating countdown timer
        floatingCountdownTimer = new System.Threading.Timer(
            _ => InvokeAsync(() => {
                if (floatingSessionData != null && DateTime.UtcNow >= floatingSessionData.EndTime)
                {
                    CloseFloatingQR();
                }
                StateHasChanged();
            }),
            null,
            TimeSpan.Zero,
            TimeSpan.FromSeconds(1)
        );
    }
    
    private void CloseFloatingQR()
    {
        showFloatingQR = false;
        floatingSessionData = null;
        floatingCountdownTimer?.Dispose();
        floatingCountdownTimer = null;
    }
    
    private void StartDrag(MouseEventArgs e)
    {
        isDragging = true;
        dragStartX = e.ClientX;
        dragStartY = e.ClientY;
        
        // Parse current window position
        var parts = floatingWindowStyle.Split(';');
        foreach (var part in parts)
        {
            var trimmed = part.Trim();
            if (trimmed.StartsWith("top:"))
                windowStartY = double.Parse(trimmed.Replace("top:", "").Replace("px", "").Trim());
            else if (trimmed.StartsWith("left:"))
                windowStartX = double.Parse(trimmed.Replace("left:", "").Replace("px", "").Trim());
        }
    }
    
    private void CleanupExpiredSessions()
    {
        var expiredSessions = activeSessions.Where(s => DateTime.UtcNow >= s.EndTime).ToList();
        foreach (var expired in expiredSessions)
        {
            activeSessions.Remove(expired);
        }
        
        // Close floating QR if current session expired
        if (floatingSessionData != null && DateTime.UtcNow >= floatingSessionData.EndTime)
        {
            CloseFloatingQR();
        }
    }
    
    private QRCodeTheme ConvertStringToTheme(string theme)
    {
        return theme switch
        {
            "Gradient" => QRCodeTheme.Gradient,
            "Branded" => QRCodeTheme.Branded,
            "GradientWithLogo" => QRCodeTheme.GradientWithLogo,
            _ => QRCodeTheme.Standard
        };
    }
    
    private QRCodeBaseOptions GenerateQRCodeOptions()
    {
        return GenerateQRCodeOptionsForTheme(selectedTheme, qrCodePayload);
    }
    
    private QRCodeBaseOptions GenerateFloatingQRCodeOptions()
    {
        return GenerateQRCodeOptionsForTheme(floatingSessionData?.Theme ?? "Standard", floatingSessionData?.QrCodePayload ?? "");
    }
    
    private QRCodeBaseOptions GenerateQRCodeOptionsForTheme(string theme, string content)
    {
        QRCodeBaseOptions options = new QRCodeBaseOptions
        {
            Content = content,
            Size = 300,
            DarkColor = "#000000",
            LightColor = "#FFFFFF",
            ErrorLevel = ErrorCorrectionLevel.M,
            Margin = 4
        };
        
        return theme switch
        {
            "Gradient" => new QRCodeGradientOptions
            {
                Content = content,
                Size = 300,
                DarkColor = "#000000",
                LightColor = "#FFFFFF",
                ErrorLevel = ErrorCorrectionLevel.M,
                Margin = 4,
                GradientColor1 = "#3498db",
                GradientColor2 = "#9b59b6",
                Direction = GradientDirection.Diagonal
            },
            "Branded" => new QRCodeBrandedOptions
            {
                Content = content,
                Size = 300,
                DarkColor = "#000000",
                LightColor = "#FFFFFF",
                ErrorLevel = ErrorCorrectionLevel.H,
                Margin = 4,
                LogoUrl = "/icon-192.png",
                LogoSizeRatio = 0.2f,
                AddLogoBorder = true,
                LogoBorderColor = "#FFFFFF",
                LogoBorderWidth = 2,
                LogoBorderRadius = 5
            },
            "GradientWithLogo" => new QRCodeGradientBrandedOptions
            {
                Content = content,
                Size = 300,
                DarkColor = "#000000",
                LightColor = "#FFFFFF",
                ErrorLevel = ErrorCorrectionLevel.H,
                Margin = 4,
                GradientColor1 = "#3498db",
                GradientColor2 = "#9b59b6",
                Direction = GradientDirection.Radial,
                LogoUrl = "/icon-192.png",
                LogoSizeRatio = 0.2f,
                AddLogoBorder = true,
                LogoBorderColor = "#FFFFFF",
                LogoBorderWidth = 2,
                LogoBorderRadius = 5
            },
            _ => options
        };
    }
    
    private string FormatTimeRemaining()
    {
        if (!isSessionStarted) return "--:--:--";
        
        TimeSpan remaining = sessionEndTime - DateTime.UtcNow;
        if (remaining.TotalSeconds <= 0)
        {
            EndSession();
            return "00:00:00";
        }
        
        return $"{remaining.Hours:00}:{remaining.Minutes:00}:{remaining.Seconds:00}";
    }
    
    private string FormatFloatingTimeRemaining()
    {
        if (floatingSessionData == null) return "--:--:--";
        
        TimeSpan remaining = floatingSessionData.EndTime - DateTime.UtcNow;
        if (remaining.TotalSeconds <= 0)
        {
            return "00:00:00";
        }
        
        return $"{remaining.Hours:00}:{remaining.Minutes:00}:{remaining.Seconds:00}";
    }
    
    private Task HandleQRCodeGenerated(QRCodeData qrCode)
    {
        generatedQRCode = qrCode;
        return Task.CompletedTask;
    }
    
    public void Dispose()
    {
        countdownTimer?.Dispose();
        floatingCountdownTimer?.Dispose();
    }
    
    // Supporting data structure for active sessions
    public class ActiveSessionData
    {
        public string SessionId { get; set; }
        public string CourseName { get; set; }
        public string CourseId { get; set; }
        public DateTime StartTime { get; set; }
        public DateTime EndTime { get; set; }
        public int Duration { get; set; }
        public string QrCodePayload { get; set; }
        public string Theme { get; set; }
    }
}