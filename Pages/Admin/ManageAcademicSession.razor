            {
                List<AcademicSession> allSessions = JsonConvert.DeserializeObject<List<AcademicSession>>(academicSessionsJson);

                if (allSessions != null && allSessions.Count > 0)
                {
                    archivedSessions.AddRange(allSessions);
                }
            }
            // For demo, create sample data
            // In production, this would be loaded from Firebase
            
            // Demo current session
            currentSession = new AcademicSession
            {
                SessionId = Guid.NewGuid().ToString(),
                YearStart = 2024,
                YearEnd = 2025,
                SecurityToken = Guid.NewGuid().ToString(),
                LastModified = DateTime.Now,
