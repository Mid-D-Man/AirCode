@page "/SupaTest"
@using AirCode.Services.SupaBase
@using System.Collections.Generic
@using AirCode.Models.Supabase
@using Newtonsoft.Json
@inject ISupabaseDatabaseService SupabaseDb
@inject IJSRuntime JSRuntime
@implements IDisposable

<h3>Supabase Test</h3>

@if (_loading)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger" role="alert">
        @_error
    </div>
}
else
{
    <div class="mb-4">
        <button class="btn btn-primary" @onclick="LoadData">Refresh Data</button>
        <button class="btn btn-success ms-2" @onclick="() => _showAddModal = true">Add New Item</button>
    </div>

    @if (_items?.Count > 0)
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td>
                            <button class="btn btn-sm btn-warning" @onclick="() => EditItem(item)">Edit</button>
                            <button class="btn btn-sm btn-danger ms-1" @onclick="() => DeleteItem(item.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No items found. Add some items to get started.</div>
    }
}

@if (_showAddModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editItem.Id == 0 ? "Add New Item" : "Edit Item")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" @bind="_editItem.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" @bind="_editItem.Description"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveItem">Save</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<TestItem> _items;
    private bool _loading = true;
    private string _error;
    private bool _showAddModal = false;
    private TestItem _editItem = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            _items = await SupabaseService.GetTestItemsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Error loading data: {ex.Message}";
            Logger.LogError(ex, "Error loading data from Supabase");
        }
        finally
        {
            _loading = false;
        }
    }

    private void EditItem(TestItem item)
    {
        _editItem = new TestItem
        {
            Id = item.Id,
            Name = item.Name,
            Description = item.Description,
            CreatedAt = item.CreatedAt
        };
        _showAddModal = true;
    }

    private async Task DeleteItem(int id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this item?"))
            return;

        _loading = true;
        try
        {
            await SupabaseService.DeleteTestItemAsync(id);
            await LoadData();
        }
        catch (Exception ex)
        {
            _error = $"Error deleting item: {ex.Message}";
            Logger.LogError(ex, "Error deleting item from Supabase");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveItem()
    {
        _loading = true;
        try
        {
            if (_editItem.Id == 0)
            {
                _editItem.CreatedAt = DateTime.UtcNow;
                await SupabaseService.AddTestItemAsync(_editItem);
            }
            else
            {
                await SupabaseService.UpdateTestItemAsync(_editItem);
            }
            
            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            _error = $"Error saving item: {ex.Message}";
            Logger.LogError(ex, "Error saving item to Supabase");
        }
        finally
        {
            _loading = false;
        }
    }

    private void CloseModal()
    {
        _showAddModal = false;
        _editItem = new TestItem();
    }

    public void Dispose()
    {
        // TODO release managed resources here
    }

}