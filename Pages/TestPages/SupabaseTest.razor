@page "/SupaTest"
@using AirCode.Services.SupaBase
@using System.Collections.Generic
@using Newtonsoft.Json
@inject ISupabaseDatabaseService SupabaseDb
@inject IJSRuntime JSRuntime
@implements IDisposable

<h3>Courses Management</h3>

<div class="offline-status @(_isOnline ? "online" : "offline")">
    @if (_isOnline)
    {
        <span>Online</span>
    }
    else
    {
        <span>Offline (Changes will sync when connection is restored)</span>
        @if (_pendingOperations > 0)
        {
            <button class="btn btn-warning" @onclick="SyncOfflineData">
                Sync (@_pendingOperations pending changes)
            </button>
        }
    }
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">
        @_errorMessage
    </div>
}

@if (_isLoading)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else
{
    <div class="row mb-3">
        <div class="col">
            <button class="btn btn-primary" @onclick="() => _showAddForm = true">Add New Course</button>
        </div>
    </div>

    @if (_showAddForm)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5>Add New Course</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@_newCourse" OnValidSubmit="AddCourse">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label for="courseCode" class="form-label">Course Code</label>
                        <InputText id="courseCode" class="form-control" @bind-Value="_newCourse.CourseCode" />
                        <ValidationMessage For="@(() => _newCourse.CourseCode)" />
                    </div>
                    <div class="mb-3">
                        <label for="courseName" class="form-label">Course Name</label>
                        <InputText id="courseName" class="form-control" @bind-Value="_newCourse.CourseName" />
                        <ValidationMessage For="@(() => _newCourse.CourseName)" />
                    </div>
                    <div class="mb-3">
                        <label for="courseDescription" class="form-label">Description</label>
                        <InputTextArea id="courseDescription" class="form-control" @bind-Value="_newCourse.Description" />
                    </div>
                    <div class="mb-3">
                        <label for="creditHours" class="form-label">Credit Hours</label>
                        <InputNumber id="creditHours" class="form-control" @bind-Value="_newCourse.CreditHours" />
                        <ValidationMessage For="@(() => _newCourse.CreditHours)" />
                    </div>
                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => _showAddForm = false">Cancel</button>
                </EditForm>
            </div>
        </div>
    }

    @if (_courses != null && _courses.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Course Code</th>
                    <th>Course Name</th>
                    <th>Description</th>
                    <th>Credit Hours</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in _courses)
                {
                    <tr>
                        <td>@course.CourseCode</td>
                        <td>@course.CourseName</td>
                        <td>@course.Description</td>
                        <td>@course.CreditHours</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => EditCourse(course)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteCourse(course.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            No courses found. Add a new course to get started.
        </div>
    }

    @if (_currentEditCourse != null)
    {
        <div class="modal" tabindex="-1" style="display: block; background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Course</h5>
                        <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                    </div>
                    <div class="modal-body">
                        <EditForm Model="@_currentEditCourse" OnValidSubmit="UpdateCourse">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label for="editCourseCode" class="form-label">Course Code</label>
                                <InputText id="editCourseCode" class="form-control" @bind-Value="_currentEditCourse.CourseCode" />
                                <ValidationMessage For="@(() => _currentEditCourse.CourseCode)" />
                            </div>
                            <div class="mb-3">
                                <label for="editCourseName" class="form-label">Course Name</label>
                                <InputText id="editCourseName" class="form-control" @bind-Value="_currentEditCourse.CourseName" />
                                <ValidationMessage For="@(() => _currentEditCourse.CourseName)" />
                            </div>
                            <div class="mb-3">
                                <label for="editCourseDescription" class="form-label">Description</label>
                                <InputTextArea id="editCourseDescription" class="form-control" @bind-Value="_currentEditCourse.Description" />
                            </div>
                            <div class="mb-3">
                                <label for="editCreditHours" class="form-label">Credit Hours</label>
                                <InputNumber id="editCreditHours" class="form-control" @bind-Value="_currentEditCourse.CreditHours" />
                                <ValidationMessage For="@(() => _currentEditCourse.CreditHours)" />
                            </div>
                            <button type="submit" class="btn btn-success">Update</button>
                            <button type="button" class="btn btn-secondary" @onclick="CloseEditModal">Cancel</button>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<CourseModel> _courses = new();
    private CourseModel _newCourse = new();
    private CourseModel? _currentEditCourse;
    private bool _isLoading = true;
    private bool _showAddForm = false;
    private string _errorMessage = string.Empty;
    private bool _isOnline = true;
    private int _pendingOperations = 0;
    private DotNetObjectReference<SupabaseTest>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("window.addEventListener", "online", _dotNetRef, "OnConnectionChange");
        await JSRuntime.InvokeVoidAsync("window.addEventListener", "offline", _dotNetRef, "OnConnectionChange");
        
        _isOnline = await JSRuntime.InvokeAsync<bool>("navigator.onLine");
        await CheckPendingOperations();
        await LoadCourses();
    }

    [JSInvokable]
    public async Task OnConnectionChange(bool isOnline)
    {
        _isOnline = isOnline;
        if (isOnline)
        {
            await LoadCourses();
        }
        await CheckPendingOperations();
        StateHasChanged();
    }

    private async Task CheckPendingOperations()
    {
        try
        {
            var offlineOps = await JSRuntime.InvokeAsync<string>("eval", "localStorage.getItem('supabase_offline_operations') || '[]'");
            var operations = JsonConvert.DeserializeObject<List<object>>(offlineOps);
            _pendingOperations = operations?.Count ?? 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking pending operations: {ex.Message}");
            _pendingOperations = 0;
        }
    }

    private async Task LoadCourses()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        
        try
        {
            var result = await SupabaseDb.GetAsync<List<CourseModel>>("courses");
            _courses = result ?? new List<CourseModel>();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load courses: {ex.Message}";
            Console.WriteLine(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddCourse()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        
        try
        {
            await SupabaseDb.InsertAsync<CourseModel>("courses", _newCourse);
            _newCourse = new CourseModel();
            _showAddForm = false;
            await LoadCourses();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to add course: {ex.Message}";
            Console.WriteLine(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void EditCourse(CourseModel course)
    {
        _currentEditCourse = new CourseModel
        {
            Id = course.Id,
            CourseCode = course.CourseCode,
            CourseName = course.CourseName,
            Description = course.Description,
            CreditHours = course.CreditHours
        };
    }

    private void CloseEditModal()
    {
        _currentEditCourse = null;
    }

    private async Task UpdateCourse()
    {
        if (_currentEditCourse == null) return;
        
        _isLoading = true;
        _errorMessage = string.Empty;
        
        try
        {
            await SupabaseDb.UpdateAsync<CourseModel>("courses", _currentEditCourse.Id, _currentEditCourse);
            _currentEditCourse = null;
            await LoadCourses();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to update course: {ex.Message}";
            Console.WriteLine(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeleteCourse(string id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this course?"))
        {
            return;
        }
        
        _isLoading = true;
        _errorMessage = string.Empty;
        
        try
        {
            await SupabaseDb.DeleteAsync<object>("courses", id);
            await LoadCourses();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete course: {ex.Message}";
            Console.WriteLine(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SyncOfflineData()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        
        try
        {
            var results = await SupabaseDb.SyncOfflineOperationsAsync();
            var successCount = results.Count(r => r.Success);
            var failCount = results.Count - successCount;
            
            if (failCount > 0)
            {
                _errorMessage = $"Sync completed with {failCount} errors. Please check the console for details.";
            }
            
            await CheckPendingOperations();
            await LoadCourses();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to sync offline data: {ex.Message}";
            Console.WriteLine(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        if (_dotNetRef != null)
        {
            JSRuntime.InvokeVoidAsync("window.removeEventListener", "online", _dotNetRef, "OnConnectionChange");
            JSRuntime.InvokeVoidAsync("window.removeEventListener", "offline", _dotNetRef, "OnConnectionChange");
            _dotNetRef.Dispose();
        }
    }

    public class CourseModel
    {
        [JsonProperty("id")]
        public string Id { get; set; } = Guid.NewGuid().ToString();
        
        [JsonProperty("course_code")]
        public string CourseCode { get; set; } = string.Empty;
        
        [JsonProperty("course_name")]
        public string CourseName { get; set; } = string.Empty;
        
        [JsonProperty("description")]
        public string Description { get; set; } = string.Empty;
        
        [JsonProperty("credit_hours")]
        public int CreditHours { get; set; } = 3;
    }
}