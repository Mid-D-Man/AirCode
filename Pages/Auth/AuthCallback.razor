@page "/authentication/login-callback"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using System.Web
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.Json.Serialization
@using AirCode.Services.Storage
@using AirCode.Utilities.HelperScripts

<div class="container mt-5">
    @if (processingAuth)
    {
        <h3>Processing login...</h3>
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else if (showProfileForm)
    {
        <div class="card">
            <div class="card-header">
                <h3>Complete Your Profile</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="studentId" class="form-label">Student ID</label>
                    <input type="text" class="form-control" id="studentId" @bind="studentId" />
                </div>
                <div class="mb-3">
                    <label for="nickname" class="form-label">Nickname</label>
                    <input type="text" class="form-control" id="nickname" @bind="nickname" />
                </div>
                <button class="btn btn-primary" @onclick="UpdateUserMetadata" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span> Saving...</span>
                    }
                    else
                    {
                        <span>Save Profile</span>
                    }
                </button>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @errorMessage
        </div>
    }
</div>

@code {
    [Inject] public NavigationManager NavigationManager { get; set; }
    [Inject] public HttpClient HttpClient { get; set; }
    [Inject] public IBlazorAppLocalStorageService LocalStorage { get; set; }
    [Inject] public IJSRuntime JSRuntime { get; set; }

    private bool processingAuth = true;
    private bool showProfileForm = false;
    private bool isSaving = false;
    private string studentId = "";
    private string nickname = "";
    private string userId = "";
    private string accessToken = "";
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = HttpUtility.ParseQueryString(uri.Query);
        var code = query["code"];

        if (!string.IsNullOrEmpty(code))
        {
            try
            {
                // Exchange code for token
                await ExchangeCodeForToken(code);
                
                // Show the profile form after successful authentication
                processingAuth = false;
                showProfileForm = true;
            }
            catch (Exception ex)
            {
                errorMessage = $"Authentication error: {ex.Message}";
                processingAuth = false;
            }
        }
        else
        {
            // Handle error
            NavigationManager.NavigateTo("/login?error=auth_failed");
        }
    }

    private async Task ExchangeCodeForToken(string code)
    {
        // Construct the token endpoint URL
        var domain = "dev-msf1vlcbx1a8wtg3.eu.auth0.com";
        var clientId = "B8U5o6PVyTkowZ9qffByDb9cs6NhZpsx";
        var redirectUri = $"{NavigationManager.BaseUri}authentication/login-callback";
        
        var tokenEndpoint = $"https://{domain}/oauth/token";
        
        // Prepare the request body
        var requestContent = new FormUrlEncodedContent(new Dictionary<string, string>
        {
            { "grant_type", "authorization_code" },
            { "client_id", clientId },
            { "code", code },
            { "redirect_uri", redirectUri }
        });

        // Send the request
        var response = await HttpClient.PostAsync(tokenEndpoint, requestContent);
        
        if (response.IsSuccessStatusCode)
        {
            var responseJson = await response.Content.ReadFromJsonAsync<TokenResponse>();
            accessToken = responseJson.AccessToken;
            
            // Get user info using the access token
            await GetUserInfo();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            throw new Exception($"Failed to exchange code for token: {error}");
        }
    }

    private async Task GetUserInfo()
    {
        var domain = "dev-msf1vlcbx1a8wtg3.eu.auth0.com";
        var userInfoEndpoint = $"https://{domain}/userinfo";
        
        var request = new HttpRequestMessage(HttpMethod.Get, userInfoEndpoint);
        request.Headers.Add("Authorization", $"Bearer {accessToken}");
        
        var response = await HttpClient.SendAsync(request);
        
        if (response.IsSuccessStatusCode)
        {
            var userInfo = await response.Content.ReadFromJsonAsync<UserInfoResponse>();
            userId = userInfo.Sub;
            
            MID_HelperFunctions.DebugMessage($"Got The following user info from auth0 {userInfo}");
            // Save the tokens and user info
            await LocalStorage.SetItemAsync("auth_access_token", accessToken);
            await LocalStorage.SetItemAsync("auth_user_id", userId);
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            throw new Exception($"Failed to get user info: {error}");
        }
    }

    private async Task UpdateUserMetadata()
    {
        if (string.IsNullOrWhiteSpace(studentId) || string.IsNullOrWhiteSpace(nickname))
        {
            errorMessage = "Please fill in both fields";
            return;
        }

        isSaving = true;
        
        try
        {
            // Get a management API token first
            var managementToken = await GetManagementApiToken();
            
            // Update the user metadata
            var domain = "dev-msf1vlcbx1a8wtg3.eu.auth0.com";
            var updateUserEndpoint = $"https://{domain}/api/v2/users/{Uri.EscapeDataString(userId)}";
            
            var updateData = new
            {
                user_metadata = new
                {
                    student_id = studentId,
                    nickname = nickname
                }
            };
            
            var request = new HttpRequestMessage(HttpMethod.Patch, updateUserEndpoint);
            request.Headers.Add("Authorization", $"Bearer {managementToken}");
            request.Content = JsonContent.Create(updateData);
            
            var response = await HttpClient.SendAsync(request);
            
            if (response.IsSuccessStatusCode)
            {
                // Store the metadata locally as well
                await LocalStorage.SetItemAsync("user_student_id", studentId);
                await LocalStorage.SetItemAsync("user_nickname", nickname);
                
                // Redirect to home or dashboard
                NavigationManager.NavigateTo("/");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to update profile: {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating profile: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task<string> GetManagementApiToken()
    {
        var domain = "dev-msf1vlcbx1a8wtg3.eu.auth0.com";
        var tokenEndpoint = $"https://{domain}/oauth/token";
        
        var requestContent = new FormUrlEncodedContent(new Dictionary<string, string>
        {
            { "grant_type", "client_credentials" },
            { "client_id", "B8U5o6PVyTkowZ9qffByDb9cs6NhZpsx" },
            { "client_secret", "C3JtLg5JtHhQsnCiT8F1h4IbFKdQgyUoag6HN6bffkRP_ztDVu4qQzhMbVm47dYY" }, // You'll need to get this from Auth0
            { "audience", $"https://{domain}/api/v2/" }
        });

        var response = await HttpClient.PostAsync(tokenEndpoint, requestContent);
        
        if (response.IsSuccessStatusCode)
        {
            var responseJson = await response.Content.ReadFromJsonAsync<TokenResponse>();
            return responseJson.AccessToken;
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            throw new Exception($"Failed to get management API token: {error}");
        }
    }

    public class TokenResponse
    {
        [JsonPropertyName("access_token")]
        public string AccessToken { get; set; }
        
        [JsonPropertyName("token_type")]
        public string TokenType { get; set; }
        
        [JsonPropertyName("expires_in")]
        public int ExpiresIn { get; set; }
    }

    public class UserInfoResponse
    {
        [JsonPropertyName("sub")]
        public string Sub { get; set; }
        
        [JsonPropertyName("name")]
        public string Name { get; set; }
        
        [JsonPropertyName("email")]
        public string Email { get; set; }

        public override string ToString()
        {
            return MID_HelperFunctions.GetStructOrClassMemberValues(this);
        }
    }
}