@page "/authentication/login-callback"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using System.Web
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.Json.Serialization
@using AirCode.Services.Storage
@using AirCode.Utilities.HelperScripts
@using System.IdentityModel.Tokens.Jwt

<div class="auth-container">
    @if (processingAuth)
    {
        <div class="auth-loading">
            <h3>Processing login...</h3>
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="auth-error">
            @errorMessage
        </div>
    }
</div>

@code {
    [Inject] public NavigationManager NavigationManager { get; set; }
    [Inject] public HttpClient HttpClient { get; set; }
    [Inject] public IBlazorAppLocalStorageService LocalStorage { get; set; }
    [Inject] public IJSRuntime JSRuntime { get; set; }

    private bool processingAuth = true;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = HttpUtility.ParseQueryString(uri.Query);
        var code = query["code"];
        var error = query["error"];

        if (!string.IsNullOrEmpty(error))
        {
            var errorDescription = query["error_description"];
            NavigationManager.NavigateTo($"/login?error={error}&error_description={errorDescription}");
            return;
        }

        if (!string.IsNullOrEmpty(code))
        {
            try
            {
                // Exchange code for token
                await ExchangeCodeForToken(code);
                
                // Redirect based on user role
                await RedirectBasedOnRole();
            }
            catch (Exception ex)
            {
                errorMessage = $"Authentication error: {ex.Message}";
                processingAuth = false;
            }
        }
        else
        {
            // Handle error
            NavigationManager.NavigateTo("/login?error=auth_failed");
        }
    }

    private async Task ExchangeCodeForToken(string code)
    {
        // Construct the token endpoint URL
        var domain = "dev-msf1vlcbx1a8wtg3.eu.auth0.com";
        var clientId = "B8U5o6PVyTkowZ9qffByDb9cs6NhZpsx";
        var redirectUri = $"{NavigationManager.BaseUri}authentication/login-callback";
        
        var tokenEndpoint = $"https://{domain}/oauth/token";
        
        // Prepare the request body
        var requestContent = new FormUrlEncodedContent(new Dictionary<string, string>
        {
            { "grant_type", "authorization_code" },
            { "client_id", clientId },
            { "code", code },
            { "redirect_uri", redirectUri }
        });

        // Send the request
        var response = await HttpClient.PostAsync(tokenEndpoint, requestContent);
        
        if (response.IsSuccessStatusCode)
        {
            var responseJson = await response.Content.ReadFromJsonAsync<TokenResponse>();
            var accessToken = responseJson.AccessToken;
            var idToken = responseJson.IdToken;
            
            // Store tokens
            await LocalStorage.SetItemAsync("auth_access_token", accessToken);
            await LocalStorage.SetItemAsync("auth_id_token", idToken);
            
            // Parse ID token to get roles
            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadJwtToken(idToken);

            // The claim name for roles depends on your Auth0 configuration
            // Common formats are roles, https://yourapp.com/roles, or https://yourauth0domain/roles
            string roleClaim = "https://dev-msf1vlcbx1a8wtg3.eu.auth0.com/roles";
            
            if (jwtToken.Claims.Any(c => c.Type == roleClaim))
            {
                var roles = jwtToken.Claims
                    .Where(c => c.Type == roleClaim)
                    .Select(c => c.Value)
                    .ToList();
                
                if (roles.Any())
                {
                    await LocalStorage.SetItemAsync("user_roles", System.Text.Json.JsonSerializer.Serialize(roles));
                    MID_HelperFunctions.DebugMessage($"User roles: {string.Join(", ", roles)}");
                }
            }
            
            // Get additional user info
            await GetUserInfo(accessToken);
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            throw new Exception($"Failed to exchange code for token: {error}");
        }
    }

    private async Task GetUserInfo(string accessToken)
    {
        var domain = "dev-msf1vlcbx1a8wtg3.eu.auth0.com";
        var userInfoEndpoint = $"https://{domain}/userinfo";
        
        var request = new HttpRequestMessage(HttpMethod.Get, userInfoEndpoint);
        request.Headers.Add("Authorization", $"Bearer {accessToken}");
        
        var response = await HttpClient.SendAsync(request);
        
        if (response.IsSuccessStatusCode)
        {
            var userInfo = await response.Content.ReadFromJsonAsync<UserInfoResponse>();
            var userId = userInfo.Sub;
            
            MID_HelperFunctions.DebugMessage($"Got The following user info from auth0 {userInfo}");
            
            // Save user info
            await LocalStorage.SetItemAsync("auth_user_id", userId);
            
            // Save user metadata if available
            if (!string.IsNullOrEmpty(userInfo.Name))
                await LocalStorage.SetItemAsync("user_name", userInfo.Name);
            
            if (!string.IsNullOrEmpty(userInfo.Email))
                await LocalStorage.SetItemAsync("user_email", userInfo.Email);
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            throw new Exception($"Failed to get user info: {error}");
        }
    }
    
    private async Task RedirectBasedOnRole()
    {
        string rolesJson = await LocalStorage.GetItemAsync<string>("user_roles");
        MID_HelperFunctions.DebugMessage("User role from local storage is" + rolesJson);
        //supposed kick user out and show error if no role cause all users suppose hav role
        // Handle users without roles
        if (string.IsNullOrEmpty(rolesJson))
        {
            MID_HelperFunctions.DebugMessage("User has no roles, redirecting to default page");
            NavigationManager.NavigateTo("/ScanPage");
            return;
        }
    
        var roles = System.Text.Json.JsonSerializer.Deserialize<List<string>>(rolesJson);
    
        // Check if roles list is empty
        if (roles == null || roles.Count == 0)
        {
            MID_HelperFunctions.DebugMessage("User has empty roles list, redirecting to default page");
            NavigationManager.NavigateTo("/ScanPage");
            return;
        }
    
        // Redirect based on role hierarchy
        if (roles.Contains("SuperiorAdmin", StringComparer.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo("/Admin/Dashboard");
        }
        else if (roles.Contains("Lecturer", StringComparer.OrdinalIgnoreCase) || 
                 roles.Contains("CoursesRep", StringComparer.OrdinalIgnoreCase) ||
                 roles.Contains("AssistantCoursesRep", StringComparer.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo("/Admin/Dashboard");
        }
        else if (roles.Contains("Student", StringComparer.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo("/ScanPage");
        }
        else
        {
            // Default route for users with roles that don't match any of our conditions
            MID_HelperFunctions.DebugMessage($"User has roles but none match our conditions: {string.Join(", ", roles)}");
            NavigationManager.NavigateTo("/ScanPage");
        }
    }

    public class TokenResponse
    {
        [JsonPropertyName("access_token")]
        public string AccessToken { get; set; }
        
        [JsonPropertyName("id_token")]
        public string IdToken { get; set; }
        
        [JsonPropertyName("token_type")]
        public string TokenType { get; set; }
        
        [JsonPropertyName("expires_in")]
        public int ExpiresIn { get; set; }
    }

    public class UserInfoResponse
    {
        [JsonPropertyName("sub")]
        public string Sub { get; set; }
        
        [JsonPropertyName("name")]
        public string Name { get; set; }
        
        [JsonPropertyName("email")]
        public string Email { get; set; }
        
        [JsonPropertyName("email_verified")]
        public bool EmailVerified { get; set; }
        
        public override string ToString()
        {
            return MID_HelperFunctions.GetStructOrClassMemberValues(this);
        }
    }
}