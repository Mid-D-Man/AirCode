@page "/authentication/{action}"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Microsoft.Extensions.Configuration
@using Microsoft.JSInterop
@using AirCode.Services.Auth
@using AirCode.Services.Auth.Offline
@using System.Text.Json
@using System.Security.Claims
@using AirCode.Services.Cryptography
@using AirCode.Utilities.HelperScripts
@using JsonSerializer = System.Text.Json.JsonSerializer
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@inject IAuthService AuthService
@inject IAccessTokenProvider TokenProvider
@inject IOfflineCredentialsService OfflineCredentialsService
@inject ICryptographyService CryptoService
<RemoteAuthenticatorView Action="@Action" OnLogInSucceeded="HandleLoginSuccess">
    <LoggingIn>
        <p>Redirecting to Auth0 login...</p>
        @{
            AuthService.LogAuthenticationMessage("Starting Auth0 login redirection");
        }
    </LoggingIn>
    <CompletingLoggingIn>
        <p>Completing login process...</p>
        @{
            AuthService.LogAuthenticationMessage("Processing login callback");
        }
    </CompletingLoggingIn>
    <LogOut>
        @{
            var authority = $"https://{Configuration["Auth0:Domain"]}";
            var clientId = Configuration["Auth0:ClientId"];
            AuthService.LogAuthenticationMessage("Logging out user");
            Navigation.NavigateTo($"{authority}/v2/logout?client_id={clientId}");
        }
    </LogOut>
</RemoteAuthenticatorView>

@code{
    [Parameter] public string Action { get; set; }
    
    private async Task HandleLoginSuccess(RemoteAuthenticationState state)
    {
        // Log successful authentication
        await AuthService.LogAuthenticationMessageAsync("(current) Authentication successful!");

        // Request the token and log its status
        var result = await TokenProvider.RequestAccessToken();

        await AuthService.LogAuthenticationMessageAsync($"(current) Access token status: {result.Status}");

        if (result.TryGetToken(out var token))
        {
            await AuthService.LogAuthenticationMessageAsync($"(current) JWT retrieved successfully. Length: {token.Value.Length} chars");
    
            // Store token in session for debugging purposes
            await JSRuntime.InvokeVoidAsync("authHelper.storeJwtLocally", token.Value);
            
          //  Navigation.NavigateTo("/auth-info", forceLoad: false);
            //return;
            try
            {
                // Extract user information from JWT
                string userId = string.Empty;
                string userRole = string.Empty;

                // Parse the JWT to extract the user ID and role
                var tokenParts = token.Value.Split('.');
                if (tokenParts.Length > 1)
                {
                    var payload = tokenParts[1];
                    var paddedPayload = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=');
                    var decodedBytes = Convert.FromBase64String(paddedPayload);
                    var jsonString = System.Text.Encoding.UTF8.GetString(decodedBytes);
                    
                    var jsonElement = JsonSerializer.Deserialize<JsonElement>(jsonString);
                    
                    // Extract user ID (sub claim)
                    if (jsonElement.TryGetProperty("sub", out var subProperty))
                    {
                        userId = subProperty.GetString();
                        await AuthService.LogAuthenticationMessageAsync($"(current) Auth0 User ID: {userId}");
                    }
                    
                    // Extract user role
                    if (jsonElement.TryGetProperty("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", out var roleProperty))
                    {
                        userRole = roleProperty.ValueKind == JsonValueKind.Array 
                            ? roleProperty.EnumerateArray().First().GetString() 
                            : roleProperty.GetString();
                        await AuthService.LogAuthenticationMessageAsync($"(current) User Role: {userRole}");
                    }
                }
                
                // Generate and store offline credentials
                if (!string.IsNullOrEmpty(userId) && !string.IsNullOrEmpty(userRole))
                {
                    var key = await CryptoService.GenerateAesKey();
                    var iv = await CryptoService.GenerateIv();
                    int expiration = 12;
                    await AuthService.LogAuthenticationMessageAsync($"Generated the following data for offline credentials userID {userId} and userRole {userRole}, key {key}, iv {iv}");
                    var credentialsResult = await OfflineCredentialsService.StoreCredentialsAsync(userId, userRole,key,iv,expiration);
                    
                    if (credentialsResult)
                    {
                        
                        await AuthService.LogAuthenticationMessageAsync("Offline credentials stored successfully");
                    }
                    else
                    {
                        await AuthService.LogAuthenticationMessageAsync("Failed to store offline credentials");
                    }
                }
                else
                {
                    await AuthService.LogAuthenticationMessageAsync($"Failed to store offline credentials beacuse something is empty userID {userId} and userRole {userRole}");
                }
                 
                // Optional: Navigate to the auth info page for debugging
                // Navigation.NavigateTo("/auth-info", forceLoad: false);
            
                // Navigate to the appropriate page based on user role
                switch (userRole?.ToLower())
                {
                    case "superioradmin":
                        MID_HelperFunctions.DebugMessage("(current) Sending to admin page sup admin",DebugClass.Log);
                        Navigation.NavigateTo("/Admin/SuperiorDashboard", forceLoad: false);
                        break;
                    case "lectureradmin":
                        MID_HelperFunctions.DebugMessage("(current) Sending to admin page lecturer",DebugClass.Log);
                        Navigation.NavigateTo("/Admin/SuperiorDashboard", forceLoad: false);
                        break;
                    case "courseadmin":
                        Navigation.NavigateTo("/Admin/SuperiorDashboard", forceLoad: false);
                        break;
                    case "student":
                        Navigation.NavigateTo("/Client/Dashboard", forceLoad: false);
                        break;
                    default:
                        // Fallback to auth info if role couldn't be determined
                        Navigation.NavigateTo("/auth-info", forceLoad: false);
                        break;
                }
            }
            catch (Exception ex)
            {
                await AuthService.LogAuthenticationMessageAsync($"Error processing JWT: {ex.Message}");
            }
           
            
        }
        else
        {
            await AuthService.LogAuthenticationMessageAsync("Failed to retrieve JWT token");
            //Navigation.NavigateTo("/"); // Fall back to homepage if token retrieval fails
        }
    }
}