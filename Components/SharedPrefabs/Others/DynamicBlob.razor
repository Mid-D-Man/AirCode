@using System
@implements IDisposable

<div class="auth-blobs">
    <div class="blob blob-1" style="background-color: @GetRandomColor(0.3)"></div>
    <div class="blob blob-2" style="background-color: @GetRandomColor(0.25)"></div>
    <div class="blob blob-3" style="background-color: @GetRandomColor(0.2)"></div>
</div>

@code {
    private string[] colorPalette = {
        "var(--primary)",
        "var(--secondary)",
        "var(--nav-background)",
        "var(--primary-color)",
        "var(--primary-rgb)"
    };

    private Random random = new Random();

    private string GetRandomColor(double opacity)
    {
        string baseColor = colorPalette[random.Next(colorPalette.Length)];
        return $"rgba(var({baseColor}), {opacity})";
    }

    public void Dispose()
    {
        // Cleanup if needed
    }
}