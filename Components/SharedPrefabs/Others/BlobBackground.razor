@* Components/SharedPrefabs/Others/BlobBackground.razor *@
<div class="main-background">
    @for (int i = 1; i <= 6; i++)
    {
        <div class="blob blob-@i">
            <div class="blob-inner" style="background-color: @GetRandomColor()"></div>
        </div>
    }
</div>

@code {
    private Random random = new Random();

    private string GetRandomColor()
    {
        string[] colors = { 
            "rgba(255, 0, 0, 0.3)", 
            "rgba(60, 0, 255, 0.3)", 
            "rgba(30, 255, 0, 0.3)", 
            "rgba(255, 107, 0, 0.3)", 
            "rgba(255, 0, 234, 0.3)", 
            "rgba(0, 255, 255, 0.3)"
        };
        return colors[random.Next(colors.Length)];
    }
}