
@using AirCode.Models

<div class="course-card">
    <div class="course-header">
        <h3 class="course-name">@Course.Name</h3>
        <span class="course-id">@Course.Id</span>
    </div>

    <div class="course-details">
        <div class="detail-item">
            <span class="label">Level:</span>
            <span class="value">@Course.Level</span>
        </div>
        <div class="detail-item">
            <span class="label">Semester:</span>
            <span class="value">@Course.Semester</span>
        </div>
        <div class="detail-item">
            <span class="label">Lecturers:</span>
            <span class="value">@GetLecturerNames()</span>
        </div>
    </div>

    <div class="schedule">
        <h4>Schedule</h4>
        <div class="schedule-items">
            @foreach (var schedule in Course.Schedule)
            {
                <div class="schedule-item">
                    <span class="day">@schedule.Day</span>
                    <span class="time">@FormatTimeSpan(schedule.StartTime) - @FormatTimeSpan(schedule.EndTime)</span>
                    <span class="location">@schedule.Location</span>
                </div>
            }
        </div>
    </div>

    <div class="course-actions">
        <button class="edit-btn" @onclick="OnEdit">Edit</button>
        <button class="delete-btn" @onclick="OnDelete">Delete</button>
    </div>
</div>

@code {
    [Parameter]
    public Course Course { get; set; }

    [Parameter]
    public EventCallback<Course> OnEditCourse { get; set; }

    [Parameter]
    public EventCallback<Course> OnDeleteCourse { get; set; }

    private async Task OnEdit()
    {
        await OnEditCourse.InvokeAsync(Course);
    }

    private async Task OnDelete()
    {
        await OnDeleteCourse.InvokeAsync(Course);
    }

    private string GetLecturerNames()
    {
        return string.Join(", ", Course.Lecturers.Select(l => $"{l.Id} - {l.Name}"));
    }


    private string FormatTimeSpan(TimeSpan time)
    {
        return time.ToString(@"hh\:mm");
    }
}