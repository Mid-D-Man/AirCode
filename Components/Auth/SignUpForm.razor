@using AirCode.Components.SharedPrefabs.Buttons
@using AirCode.Components.SharedPrefabs.Fields
@inject IJSRuntime JSRuntime

<div class="signup-form-container">
    <div class="progress-container">
        <div class="progress-bar" style="width: @($"{((currentStep / 3.0) * 100)}%")"></div>
    </div>

    <div class="step-indicator">
        Step @(currentStep) of 3
    </div>

    <EditForm Model="@signUpModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        @switch (currentStep)
        {
            case 1:
                <div class="step-content">
                    <div class="form-group">
                        <FormField
                            Label="First Name"
                            @bind-Value="signUpModel.FirstName"
                            Placeholder="Enter your first name"
                            IsRequired="true" />
                    </div>
                    <div class="form-group">
                        <FormField
                            Label="Middle Name"
                            @bind-Value="signUpModel.MiddleName"
                            Placeholder="Enter your middle name (optional)" />
                    </div>
                    <div class="form-group">
                        <FormField
                            Label="Last Name"
                            @bind-Value="signUpModel.LastName"
                            Placeholder="Enter your last name"
                            IsRequired="true" />
                    </div>
                </div>
                break;

            case 2:
                <div class="step-content">
                    <div class="form-group">
                        <label class="date-label required">Date of Birth</label>
                        <InputDate @bind-Value="signUpModel.DateOfBirth" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label class="select-label required">Gender</label>
                        <InputSelect @bind-Value="signUpModel.Gender" class="form-input">
                            <option value="" disabled selected>Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </InputSelect>
                    </div>
                </div>
                break;

            case 3:
                <div class="step-content">
                    <div class="form-group">
                        <FormField
                            Label="Email"
                            Type="email"
                            @bind-Value="signUpModel.Email"
                            Placeholder="Enter your email address"
                            IsRequired="true" />
                    </div>
                    <div class="form-group">
                        <FormField
                            Label="Matriculation Number"
                            @bind-Value="signUpModel.MatriculationNumber"
                            Placeholder="Enter your matriculation number"
                            IsRequired="true" />
                    </div>
                    <div class="form-group admin-checkbox">
                        <label class="checkbox-container">
                            <input type="checkbox" checked="@signUpModel.IsAdmin" @onchange="AdminCheckChanged" />
                            <span class="checkbox-text">Sign up as Administrator</span>
                        </label>
                    </div>
                    @if (signUpModel.IsAdmin)
                    {
                        <div class="form-group admin-id-section">
                            <FormField
                                Label="Admin ID"
                                @bind-Value="signUpModel.AdminId"
                                Placeholder="Enter Admin ID"
                                IsRequired="true" />
                        </div>
                    }
                </div>
                break;
        }

        <div class="form-navigation">
            @if (currentStep > 1)
            {
                <div class="nav-button prev-button">
                    <PrimaryButton
                        Text="Previous"
                        OnClick="PreviousStep"
                        Class="secondary" />
                </div>
            }

            <div class="nav-button @(currentStep < 3 ? "next-button" : "submit-button")">
                @if (currentStep < 3)
                {
                    <PrimaryButton
                        Text="Next"
                        OnClick="NextStep" />
                }
                else
                {
                    <PrimaryButton
                        Type="submit"
                        Text="Complete Sign Up" />
                }
            </div>
        </div>
    </EditForm>
</div>

@code {
    private SignUpModel signUpModel = new();
    private int currentStep = 1;

    [Parameter]
    public EventCallback<SignUpModel> OnSignUp { get; set; }

    private async Task AdminCheckChanged(ChangeEventArgs e)
    {
        if (e.Value is bool isChecked)
        {
            signUpModel.IsAdmin = isChecked;
            
            // Force UI refresh
            StateHasChanged();
        }
    }

    private void NextStep()
    {
        if (currentStep < 3) currentStep++;
    }

    private void PreviousStep()
    {
        if (currentStep > 1) currentStep--;
    }

    private async Task HandleSubmit()
    {
        await OnSignUp.InvokeAsync(signUpModel);
    }
}